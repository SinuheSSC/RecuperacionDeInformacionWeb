  <rdf:Description rdf:about="http://data.orbitalview.org/instance/news_11">
    <rdf:type rdf:resource="http://data.orbitalview.org/ontology/NewsArticle"/>
    <onto:headline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">La OCDE advierte de que algunas economías entrarán en recesión si el bloqueo del estrecho de Ormuz se prolonga</onto:headline>
    <onto:content rdf:datatype="http://www.w3.org/2001/XMLSchema#string">El organismo sube una décima, hasta el 2,2%, sus perspectivas de crecimiento para España este año, la única gran economía del euro que mejora</onto:content>
    <onto:sourceURL rdf:resource="https://elpais.com/economia/2026-06-03/la-ocde-advierte-de-que-algunas-economias-entraran-en-recesion-si-el-bloqueo-del-estrecho-de-ormuz-se-prolonga.html"/>
    <onto:publishDate rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wed, 03 Jun 2026 07:00:46 GMT</onto:publishDate>
    <onto:writtenBy rdf:resource="http://data.orbitalview.org/instance/person_Álvaro_Sánchez"/>
    <onto:assignedTo rdf:resource="http://data.orbitalview.org/instance/section_economia"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.orbitalview.org/instance/news_21">
    <rdf:type rdf:resource="http://data.orbitalview.org/ontology/NewsArticle"/>
    <onto:headline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Cuidado con usar la IA sin permiso, puede acabar en despido</onto:headline>
    <onto:content rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Cada vez más empleados recurren a esta tecnología por su cuenta, mientras muchas empresas siguen sin controlarla</onto:content>
    <onto:sourceURL rdf:resource="https://elpais.com/economia/negocios/2026-05-31/cuidado-con-usar-la-ia-sin-permiso-puede-acabar-en-despido.html"/>
    <onto:publishDate rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Sun, 31 May 2026 03:30:00 GMT</onto:publishDate>
    <onto:writtenBy rdf:resource="http://data.orbitalview.org/instance/person_Jorge__Velasco_García"/>
    <onto:assignedTo rdf:resource="http://data.orbitalview.org/instance/section_economia"/>
  </rdf:Description>
