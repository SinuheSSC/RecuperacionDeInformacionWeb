  <rdf:Description rdf:about="http://data.orbitalview.org/instance/news_15">
    <rdf:type rdf:resource="http://data.orbitalview.org/ontology/NewsArticle"/>
    <onto:headline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">El empleo de extranjeros acelera más que nunca con 289.000 nuevos puestos en el último año</onto:headline>
    <onto:content rdf:datatype="http://www.w3.org/2001/XMLSchema#string">El Gobierno cree que es pronto para relacionar estas cifras con la regularización extraordinaria de trabajadores foráneos</onto:content>
    <onto:sourceURL rdf:resource="https://elpais.com/economia/2026-06-03/el-empleo-de-extranjeros-acelera-mas-que-nunca-con-289000-nuevos-puestos-en-el-ultimo-ano.html"/>
    <onto:publishDate rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wed, 03 Jun 2026 03:45:01 GMT</onto:publishDate>
    <onto:writtenBy rdf:resource="http://data.orbitalview.org/instance/person_Emilio_Sánchez_Hidalgo"/>
    <onto:assignedTo rdf:resource="http://data.orbitalview.org/instance/section_economia"/>
  </rdf:Description>
