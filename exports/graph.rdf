  <rdf:Description rdf:about="http://data.orbitalview.org/instance/news_18">
    <rdf:type rdf:resource="http://data.orbitalview.org/ontology/NewsArticle"/>
    <onto:headline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">El Ministerio de Trabajo recomienda el teletrabajo en los municipios que visitará el Papa</onto:headline>
    <onto:content rdf:datatype="http://www.w3.org/2001/XMLSchema#string">El departamento de Yolanda Díaz pide “reducir los desplazamientos innecesarios” en las localidades afectadas en Madrid, Cataluña y Canarias</onto:content>
    <onto:sourceURL rdf:resource="https://elpais.com/economia/2026-06-02/el-ministerio-de-trabajo-recomienda-el-teletrabajo-en-los-municipios-que-visitara-el-papa.html"/>
    <onto:publishDate rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Tue, 02 Jun 2026 08:18:08 GMT</onto:publishDate>
