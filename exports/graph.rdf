  <rdf:Description rdf:about="http://data.orbitalview.org/instance/news_29">
    <rdf:type rdf:resource="http://data.orbitalview.org/ontology/NewsArticle"/>
    <onto:headline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">La Consejería de Educación de Madrid, de nuevo condenada por negar el sueldo de verano a una profesora interna</onto:headline>
    <onto:content rdf:datatype="http://www.w3.org/2001/XMLSchema#string">El Tribunal Superior de Justicia de Madrid condena a la consejería a pagar más de 4.000 euros con intereses a una docente</onto:content>
    <onto:sourceURL rdf:resource="https://elpais.com/economia/mis-derechos/2026-05-21/la-consejeria-de-educacion-de-madrid-de-nuevo-condenada-por-negar-el-sueldo-de-verano-a-una-profesora-interna.html"/>
    <onto:publishDate rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Thu, 21 May 2026 10:23:22 GMT</onto:publishDate>
