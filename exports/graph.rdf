  <rdf:Description rdf:about="http://data.orbitalview.org/instance/news_28">
    <rdf:type rdf:resource="http://data.orbitalview.org/ontology/NewsArticle"/>
    <onto:headline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Una motorista sin casco es arrollada por un turismo y muere, ¿cuál debe ser la indemnización si falleció por un golpe en la cabeza?</onto:headline>
    <onto:content rdf:datatype="http://www.w3.org/2001/XMLSchema#string">El Tribunal Supremo aclara cómo repartir la responsabilidad en accidentes donde la culpa es compartida por las partes involucradas</onto:content>
    <onto:sourceURL rdf:resource="https://elpais.com/economia/mis-derechos/2026-06-02/una-motorista-sin-casco-es-arrollada-por-un-turismo-y-muere-cual-debe-ser-la-indemnizacion-si-fallecio-por-un-golpe-en-la-cabeza.html"/>
    <onto:publishDate rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Tue, 02 Jun 2026 06:30:00 GMT</onto:publishDate>
