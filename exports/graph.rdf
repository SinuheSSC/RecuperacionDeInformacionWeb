    <onto:assignedTo rdf:resource="http://data.orbitalview.org/instance/section_economia"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.orbitalview.org/instance/news_24">
    <rdf:type rdf:resource="http://data.orbitalview.org/ontology/NewsArticle"/>
    <onto:headline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">¿Dónde está el límite de la Bolsa? Anthropic y SpaceX miden un mercado contradictorio</onto:headline>
    <onto:content rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Las valoraciones exigentes ponen a prueba la racha bursátil, pero, irónicamente, las apuestas bajistas indican un nuevo impulso</onto:content>
    <onto:sourceURL rdf:resource="https://cincodias.elpais.com/mercados-financieros/2026-06-03/donde-esta-el-limite-de-la-bolsa-anthropic-y-spacex-miden-un-mercado-contradictorio.html"/>
    <onto:publishDate rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wed, 03 Jun 2026 03:25:00 GMT</onto:publishDate>
    <onto:writtenBy rdf:resource="http://data.orbitalview.org/instance/person_Caio_Mattos"/>
    <onto:assignedTo rdf:resource="http://data.orbitalview.org/instance/section_economia"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.orbitalview.org/instance/news_9">
    <rdf:type rdf:resource="http://data.orbitalview.org/ontology/NewsArticle"/>
    <onto:headline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">CC OO exige un plan de choque ante el colapso en los tribunales laborales: un año de media para celebrar un juicio por despido</onto:headline>
    <onto:content rdf:datatype="http://www.w3.org/2001/XMLSchema#string">El sindicato denuncia que 41 provincias superan los seis meses de media para iniciar las reclamaciones de cantidad o reconocimiento de derechos laborales</onto:content>
    <onto:sourceURL rdf:resource="https://elpais.com/economia/2026-06-03/cc-oo-exige-un-plan-de-choque-ante-el-colapso-en-los-tribunales-laborales-un-ano-de-media-para-celebrar-un-juicio-por-despido.html"/>
    <onto:publishDate rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wed, 03 Jun 2026 16:19:33 GMT</onto:publishDate>
    <onto:writtenBy rdf:resource="http://data.orbitalview.org/instance/person_Raquel_Cortés_Pascual"/>
    <onto:assignedTo rdf:resource="http://data.orbitalview.org/instance/section_economia"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.orbitalview.org/instance/news_12">
    <rdf:type rdf:resource="http://data.orbitalview.org/ontology/NewsArticle"/>
    <onto:headline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Telefónica, Vodafone y MasOrange refuerzan sus redes ante la visita del Papa</onto:headline>
    <onto:content rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Las tres operadoras despliegan planes de 5G para evitar la saturación de los servicios en Madrid, Barcelona y Canarias</onto:content>
    <onto:sourceURL rdf:resource="https://elpais.com/economia/2026-06-03/telefonica-vodafone-y-masorange-refuerzan-sus-redes-ante-la-visita-del-papa.html"/>
    <onto:publishDate rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wed, 03 Jun 2026 12:16:43 GMT</onto:publishDate>
    <onto:writtenBy rdf:resource="http://data.orbitalview.org/instance/person_EL_PAÍS"/>
    <onto:assignedTo rdf:resource="http://data.orbitalview.org/instance/section_economia"/>
  </rdf:Description>
