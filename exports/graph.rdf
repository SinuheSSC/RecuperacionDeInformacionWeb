  <rdf:Description rdf:about="http://data.orbitalview.org/instance/news_17">
    <rdf:type rdf:resource="http://data.orbitalview.org/ontology/NewsArticle"/>
    <onto:headline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">La economía gana 232.000 empleos en mayo, el mayor impulso en ocho años, pero la caída del paro se resiente</onto:headline>
    <onto:content rdf:datatype="http://www.w3.org/2001/XMLSchema#string">La afiliación total alcanza un nuevo récord de 22,3 millones, con un fuerte avance de los extranjeros. El desempleo registrado retrocede en 36.300 personas, uno de los peores registros en ese mes desde 2012</onto:content>
    <onto:sourceURL rdf:resource="https://elpais.com/economia/2026-06-02/la-economia-gana-232000-empleos-en-mayo-el-mayor-impulso-en-ocho-anos-pero-la-caida-del-paro-se-resiente.html"/>
    <onto:publishDate rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Tue, 02 Jun 2026 07:00:06 GMT</onto:publishDate>
