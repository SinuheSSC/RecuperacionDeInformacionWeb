  <rdf:Description rdf:about="http://data.orbitalview.org/instance/news_4">
    <rdf:type rdf:resource="http://data.orbitalview.org/ontology/NewsArticle"/>
    <onto:headline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">La realidad paralela de Trump, en otra dimensión</onto:headline>
    <onto:content rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A diferencia de Clinton y Obama, no rectifica
ante el rechazo ciudadano y niega la realidad</onto:content>
    <onto:sourceURL rdf:resource="https://cincodias.elpais.com/opinion/2026-06-03/la-realidad-paralela-de-trump-en-otra-dimension.html"/>
