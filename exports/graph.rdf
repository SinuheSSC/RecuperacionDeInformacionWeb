  </rdf:Description>
  <rdf:Description rdf:about="http://data.orbitalview.org/instance/news_27">
    <rdf:type rdf:resource="http://data.orbitalview.org/ontology/NewsArticle"/>
    <onto:headline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Diego Abaitua (Renta 4): “Estamos abiertos a compras en banca privada, pero las valoraciones no están justificadas”</onto:headline>
    <onto:content rdf:datatype="http://www.w3.org/2001/XMLSchema#string">El secretario general y director de banca privada de la entidad defiende un modelo sin clasificaciones. El banco cuenta con cerca de 7.000 clientes con más de 500.000 euros cada uno</onto:content>
    <onto:sourceURL rdf:resource="https://cincodias.elpais.com/mercados-financieros/2026-06-03/diego-abaitua-renta-4-estamos-abiertos-a-compras-en-banca-privada-pero-las-valoraciones-no-estan-justificadas.html"/>
    <onto:publishDate rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wed, 03 Jun 2026 03:30:01 GMT</onto:publishDate>
    <onto:writtenBy rdf:resource="http://data.orbitalview.org/instance/person_Pablo_Martín_Simón"/>
    <onto:assignedTo rdf:resource="http://data.orbitalview.org/instance/section_economia"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.orbitalview.org/instance/news_23">
    <rdf:type rdf:resource="http://data.orbitalview.org/ontology/NewsArticle"/>
    <onto:headline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Casa Radio, el mastodóntico edificio de Rumania que ha degenerado en un conflicto judicial multimillonario</onto:headline>
    <onto:content rdf:datatype="http://www.w3.org/2001/XMLSchema#string">El sueño megalómano de Ceausescu se ha convertido en el mayor escándalo inmobiliario del país</onto:content>
    <onto:sourceURL rdf:resource="https://elpais.com/economia/negocios/carta-del-corresponsal/2026-05-30/casa-radio-el-mastodontico-edificio-de-rumania-que-ha-degenerado-en-un-conflicto-judicial-multimillonario.html"/>
    <onto:publishDate rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Sat, 30 May 2026 03:30:00 GMT</onto:publishDate>
