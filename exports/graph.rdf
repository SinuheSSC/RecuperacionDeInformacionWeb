  <rdf:Description rdf:about="http://data.orbitalview.org/instance/news_22">
    <rdf:type rdf:resource="http://data.orbitalview.org/ontology/NewsArticle"/>
    <onto:headline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Por qué las Bolsas están en máximos a pesar de los ‘shocks’ geopolíticos: “Cuanto más caos, más estímulos se aprueban”</onto:headline>
    <onto:content rdf:datatype="http://www.w3.org/2001/XMLSchema#string">El mayor gasto de gobiernos, empresas y familias compensa la incertidumbre bélica, según los expertos de JP Morgan Asset Management</onto:content>
    <onto:sourceURL rdf:resource="https://elpais.com/economia/negocios/2026-05-31/por-que-las-bolsas-estan-en-maximos-a-pesar-de-los-shocks-geopoliticos-cuanto-mas-caos-mas-estimulos-se-aprueban.html"/>
    <onto:publishDate rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Sun, 31 May 2026 03:30:00 GMT</onto:publishDate>
    <onto:writtenBy rdf:resource="http://data.orbitalview.org/instance/person_David_Fernández_Díaz"/>
    <onto:assignedTo rdf:resource="http://data.orbitalview.org/instance/section_economia"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.orbitalview.org/instance/news_13">
    <rdf:type rdf:resource="http://data.orbitalview.org/ontology/NewsArticle"/>
    <onto:headline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">España propone a México duplicar el comercio bilateral para 2030</onto:headline>
    <onto:content rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Sheinbaum se reúne por videoconferencia con el vicepresidente Carlos Cuerpo, al no poder llegar a Palacio Nacional por las protestas de los maestros en la capital mexicana</onto:content>
    <onto:sourceURL rdf:resource="https://elpais.com/mexico/economia/2026-06-02/espana-propone-a-mexico-duplicar-el-comercio-bilateral-para-2030.html"/>
    <onto:publishDate rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Tue, 02 Jun 2026 19:04:32 GMT</onto:publishDate>
    <onto:writtenBy rdf:resource="http://data.orbitalview.org/instance/person_Sonia_Corona"/>
    <onto:assignedTo rdf:resource="http://data.orbitalview.org/instance/section_economia"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.orbitalview.org/instance/news_7">
    <rdf:type rdf:resource="http://data.orbitalview.org/ontology/NewsArticle"/>
    <onto:headline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Las poderosas razones que tiene la vivienda para seguir subiendo</onto:headline>
    <onto:content rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Sólo un alza muy prolongada de los tipos de interés desactivará un mercado en el que la oferta no alcanza a la demanda</onto:content>
    <onto:sourceURL rdf:resource="https://cincodias.elpais.com/opinion/2026-06-03/las-poderosas-razones-que-tiene-la-vivienda-para-seguir-subiendo.html"/>
    <onto:publishDate rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wed, 03 Jun 2026 03:40:00 GMT</onto:publishDate>
    <onto:writtenBy rdf:resource="http://data.orbitalview.org/instance/person_JOSE_ANTONIO_VEGA_VEGA"/>
    <onto:assignedTo rdf:resource="http://data.orbitalview.org/instance/section_economia"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.orbitalview.org/instance/news_10">
    <rdf:type rdf:resource="http://data.orbitalview.org/ontology/NewsArticle"/>
    <onto:headline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Trump plantea nuevos aranceles a la UE, China o México basados en supuestos incumplimientos de las reglas de trabajo forzado</onto:headline>
    <onto:content rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Estados Unidos busca reconstruir su política arancelaria después de la derrota en el Supremo y planea aplicar un gravamen de al menos un 10% a decenas de países</onto:content>
    <onto:sourceURL rdf:resource="https://elpais.com/economia/2026-06-03/trump-plantea-nuevos-aranceles-a-la-ue-china-o-mexico-basados-en-supuestos-incumplimientos-de-las-reglas-de-trabajo-forzado.html"/>
    <onto:publishDate rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wed, 03 Jun 2026 13:29:42 GMT</onto:publishDate>
    <onto:writtenBy rdf:resource="http://data.orbitalview.org/instance/person_María_Sahuquillo_,Jesús-Sérvulo_González_Moreno"/>
    <onto:assignedTo rdf:resource="http://data.orbitalview.org/instance/section_economia"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.orbitalview.org/instance/news_19">
    <rdf:type rdf:resource="http://data.orbitalview.org/ontology/NewsArticle"/>
    <onto:headline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Elon Musk lleva a Wall Street al espacio: SpaceX, las claves de la empresa que intenta colonizar Marte con la mayor salida a Bolsa de la historia</onto:headline>
    <onto:content rdf:datatype="http://www.w3.org/2001/XMLSchema#string">El hombre más rico del mundo ultima la venta de acciones de su compañía de cohetes, satélites e IA, una operación de 75.000 millones de dólares envuelta en polémica</onto:content>
    <onto:sourceURL rdf:resource="https://elpais.com/economia/negocios/2026-05-30/elon-musk-lleva-a-wall-street-al-espacio-spacex-las-claves-de-la-empresa-que-intenta-colonizar-marte-con-la-mayor-salida-a-bolsa-de-la-historia.html"/>
    <onto:publishDate rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Sat, 30 May 2026 15:45:00 GMT</onto:publishDate>
    <onto:writtenBy rdf:resource="http://data.orbitalview.org/instance/person_Jesús-Sérvulo_González_Moreno"/>
    <onto:assignedTo rdf:resource="http://data.orbitalview.org/instance/section_economia"/>
  </rdf:Description>
