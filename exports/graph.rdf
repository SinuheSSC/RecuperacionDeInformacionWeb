  <rdf:Description rdf:about="http://data.orbitalview.org/instance/news_2">
    <rdf:type rdf:resource="http://data.orbitalview.org/ontology/NewsArticle"/>
    <onto:headline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bruselas quiere reforzar el músculo tecnológico de Europa para reducir su dependencia de EE UU y China</onto:headline>
    <onto:content rdf:datatype="http://www.w3.org/2001/XMLSchema#string">La Comisión Europea plantea aumentar la producción de semiconductores y triplicar la capacidad de los centros de datos en Europa con vistas a asegurar la soberanía tecnológica del continente</onto:content>
    <onto:sourceURL rdf:resource="https://elpais.com/economia/2026-06-03/bruselas-quiere-reforzar-el-musculo-tecnologico-de-europa-para-reducir-su-dependencia-de-ee-uu-y-china.html"/>
    <onto:publishDate rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wed, 03 Jun 2026 15:41:14 GMT</onto:publishDate>
    <onto:writtenBy rdf:resource="http://data.orbitalview.org/instance/person_Silvia_Ayuso"/>
    <onto:assignedTo rdf:resource="http://data.orbitalview.org/instance/section_economia"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.orbitalview.org/instance/news_1">
    <rdf:type rdf:resource="http://data.orbitalview.org/ontology/NewsArticle"/>
    <onto:headline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Meliá también cede ante la presión de Trump y abandona la gestión de 15 hoteles en Cuba</onto:headline>
    <onto:content rdf:datatype="http://www.w3.org/2001/XMLSchema#string">La decisión, comunicada a la CNMV, se produce tan solo un día después de que Iberostar anunciara que retira su marca a 12 establecimientos en la isla</onto:content>
    <onto:sourceURL rdf:resource="https://elpais.com/economia/2026-06-03/melia-tambien-cede-ante-la-presion-de-trump-y-abandona-la-gestion-de-15-hoteles-en-cuba.html"/>
    <onto:publishDate rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wed, 03 Jun 2026 08:38:19 GMT</onto:publishDate>
    <onto:writtenBy rdf:resource="http://data.orbitalview.org/instance/person_Carlos_Molina_Infante"/>
    <onto:assignedTo rdf:resource="http://data.orbitalview.org/instance/section_economia"/>
