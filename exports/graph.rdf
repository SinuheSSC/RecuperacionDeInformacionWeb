  <rdf:Description rdf:about="http://data.orbitalview.org/instance/news_8">
    <rdf:type rdf:resource="http://data.orbitalview.org/ontology/NewsArticle"/>
    <onto:headline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">La justicia europea anula en parte la condición de Meta como guardián de mercado</onto:headline>
    <onto:content rdf:datatype="http://www.w3.org/2001/XMLSchema#string">El Tribunal General de la UE avala que la Comisión otorgara esa desingnación con respecto a Messenger pero la anula en relación a Marketplace</onto:content>
    <onto:sourceURL rdf:resource="https://elpais.com/economia/2026-06-03/la-justicia-europea-anula-en-parte-la-condicion-de-meta-como-guardian-de-mercado.html"/>
