  </rdf:Description>
  <rdf:Description rdf:about="http://data.orbitalview.org/instance/news_16">
    <rdf:type rdf:resource="http://data.orbitalview.org/ontology/NewsArticle"/>
    <onto:headline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">¿Qué hacemos si el casero no nos comunica si va a ampliar el contrato? Somos jubilados y vivimos en esta casa desde 2020</onto:headline>
    <onto:content rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Los lectores envían sus preguntas al consultorio de vivienda de EL PAÍS en colaboración con Legálitas</onto:content>
    <onto:sourceURL rdf:resource="https://elpais.com/economia/vivienda/consultorio/2026-06-03/que-hacemos-si-el-casero-no-nos-comunica-si-va-a-ampliar-el-contrato-somos-jubilados-y-vivimos-en-esta-casa-desde-2020.html"/>
    <onto:publishDate rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wed, 03 Jun 2026 03:30:00 GMT</onto:publishDate>
    <onto:writtenBy rdf:resource="http://data.orbitalview.org/instance/person_Ramón_Menendez_(abogado_de_Legálitas)"/>
    <onto:assignedTo rdf:resource="http://data.orbitalview.org/instance/section_economia"/>
  </rdf:Description>
