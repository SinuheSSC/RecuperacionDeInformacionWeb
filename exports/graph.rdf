  <rdf:Description rdf:about="http://data.orbitalview.org/instance/news_3">
    <rdf:type rdf:resource="http://data.orbitalview.org/ontology/NewsArticle"/>
    <onto:headline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Las claves de un ultimátum: cómo Washington consumó el jaque al decaído turismo en Cuba</onto:headline>
    <onto:content rdf:datatype="http://www.w3.org/2001/XMLSchema#string">La orden ejecutiva del 1 de mayo, que amenaza con congelar los activos de las empresas extranjeras en la isla, tomará efecto el viernes</onto:content>
    <onto:sourceURL rdf:resource="https://elpais.com/mexico/2026-06-03/las-claves-de-un-ultimatum-como-washington-consumo-el-jaque-al-decaido-turismo-en-cuba.html"/>
    <onto:publishDate rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wed, 03 Jun 2026 03:45:01 GMT</onto:publishDate>
