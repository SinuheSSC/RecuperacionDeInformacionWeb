  <rdf:Description rdf:about="http://data.orbitalview.org/instance/news_26">
    <rdf:type rdf:resource="http://data.orbitalview.org/ontology/NewsArticle"/>
    <onto:headline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">La revolución tecnológica de la IA muta en la mayor disputa financiera de la historia</onto:headline>
    <onto:content rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Alphabet reta con una colocación de acciones de 80.000 millones, respaldada por Berkshire Hathaway, a las salidas a Bolsa de SpaceX, Anthropic y OpenAI</onto:content>
    <onto:sourceURL rdf:resource="https://cincodias.elpais.com/companias/2026-06-03/la-revolucion-tecnologica-de-la-ia-muta-en-la-mayor-disputa-financiera-de-la-historia.html"/>
