  <rdf:Description rdf:about="http://data.orbitalview.org/instance/news_8">
    <rdf:type rdf:resource="http://data.orbitalview.org/ontology/NewsArticle"/>
    <onto:headline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Shokz OpenFit Pro: el ruido sin taparse los oídos</onto:headline>
    <onto:content rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Los OpenFit Pro incorporan cancelación de ruido en un diseño de oreja abierta. La tecnología funciona mejor de lo esperado, y el resultado es el auricular deportivo más completo que ha hecho Shokz hasta la fecha.&amp;nbsp;Leer</onto:content>
    <onto:sourceURL rdf:resource="https://www.elmundo.es/tecnologia/gadgets/2026/05/29/6a1966a3e4d4d87a528b4587.html"/>
    <onto:publishDate rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Fri, 29 May 2026 12:13:29 +0200</onto:publishDate>
    <onto:writtenBy rdf:resource="http://data.orbitalview.org/instance/person_E.M."/>
    <onto:assignedTo rdf:resource="http://data.orbitalview.org/instance/section_tecnologia"/>
  </rdf:Description>
