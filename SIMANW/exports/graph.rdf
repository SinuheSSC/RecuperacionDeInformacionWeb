    <onto:assignedTo rdf:resource="http://data.orbitalview.org/instance/section_tecnologia"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.orbitalview.org/instance/news_14">
    <rdf:type rdf:resource="http://data.orbitalview.org/ontology/NewsArticle"/>
    <onto:headline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">CapCut y Gemini se asocian para editar imágenes y vídeos y hacerle la vida mucho más sencilla a los creadores de contenido</onto:headline>
    <onto:content rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Con esta colaboración, el usuario podrá generar ideas, crear el contenido y perfeccionarlo sin tener que salir de la aplicación de Gemini&amp;nbsp;Leer</onto:content>
    <onto:sourceURL rdf:resource="https://www.elmundo.es/tecnologia/2026/05/21/6a0ed61a21efa096068b45a5.html"/>
    <onto:publishDate rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Thu, 21 May 2026 11:58:43 +0200</onto:publishDate>
