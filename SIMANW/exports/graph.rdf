    <onto:publishDate rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wed, 20 May 2026 12:34:30 +0200</onto:publishDate>
    <onto:writtenBy rdf:resource="http://data.orbitalview.org/instance/person_Enrique_Carrasquilla_C."/>
    <onto:assignedTo rdf:resource="http://data.orbitalview.org/instance/section_tecnologia"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.orbitalview.org/instance/news_10">
    <rdf:type rdf:resource="http://data.orbitalview.org/ontology/NewsArticle"/>
    <onto:headline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mini PC o portátil: cómo elegir el ordenador adecuado para tus necesidades</onto:headline>
    <onto:content rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Comparamos las ventajas y desventajas de los mini PC y los portátiles para entender a quién le conviene  cada opción&amp;nbsp;Leer</onto:content>
