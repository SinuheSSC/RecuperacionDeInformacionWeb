  <rdf:Description rdf:about="http://data.orbitalview.org/instance/news_0">
    <rdf:type rdf:resource="http://data.orbitalview.org/ontology/NewsArticle"/>
    <onto:headline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Microsoft lanza un mini PC para desarrolladores que ejecuta modelos de IA sin pasar por la nube</onto:headline>
    <onto:content rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Surface RTX Spark Dev Box monta los últimos chips de NVIDIA, capaces de alcanzar un petaflop (mil billones de operaciones por segundo) y 128 GB de memoria unificada&amp;nbsp;Leer</onto:content>
    <onto:sourceURL rdf:resource="https://www.elmundo.es/tecnologia/creadores/2026/06/02/6a1f1d65e4d4d811458b45bb.html"/>
    <onto:publishDate rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Tue, 02 Jun 2026 20:14:31 +0200</onto:publishDate>
    <onto:writtenBy rdf:resource="http://data.orbitalview.org/instance/person_Ángel_Jiménez_de_Luis"/>
    <onto:assignedTo rdf:resource="http://data.orbitalview.org/instance/section_tecnologia"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.orbitalview.org/instance/news_5">
    <rdf:type rdf:resource="http://data.orbitalview.org/ontology/NewsArticle"/>
    <onto:headline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Sony cambia de estrategia: anuncia un nuevo 'God of War' sin Kratos como protagonista tras 21 años al frente de la saga</onto:headline>
    <onto:content rdf:datatype="http://www.w3.org/2001/XMLSchema#string">La compañía inaugura la semana del Summer Game Fest poniendo fecha a otros esperados juegos del catálogo de PS5 como el de Lobezno&amp;nbsp;Leer</onto:content>
    <onto:sourceURL rdf:resource="https://www.elmundo.es/tecnologia/videojuegos/2026/06/03/6a1fbf09e4d4d8d9088b45ad.html"/>
    <onto:publishDate rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wed, 03 Jun 2026 07:44:40 +0200</onto:publishDate>
    <onto:writtenBy rdf:resource="http://data.orbitalview.org/instance/person_Raquel_Díaz"/>
    <onto:assignedTo rdf:resource="http://data.orbitalview.org/instance/section_tecnologia"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.orbitalview.org/instance/news_11">
    <rdf:type rdf:resource="http://data.orbitalview.org/ontology/NewsArticle"/>
    <onto:headline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">MacBook Air M5: en busca de un nuevo propósito</onto:headline>
    <onto:content rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Apple ha actualizado este año su ordenador más popular con el chip M5, Wi-Fi 7 y el doble de almacenamiento de partida. Cuesta 1.199 euros, pero ya no es el Mac más barato y ahora debe buscar su hueco entre el Neo y el Pro&amp;nbsp;Leer</onto:content>
    <onto:sourceURL rdf:resource="https://www.elmundo.es/tecnologia/2026/05/26/6a15eeabe9cf4ad4568b458d.html"/>
    <onto:publishDate rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Tue, 26 May 2026 21:04:17 +0200</onto:publishDate>
    <onto:writtenBy rdf:resource="http://data.orbitalview.org/instance/person_Ángel_Jiménez_de_Luis."/>
    <onto:assignedTo rdf:resource="http://data.orbitalview.org/instance/section_tecnologia"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.orbitalview.org/instance/news_2">
    <rdf:type rdf:resource="http://data.orbitalview.org/ontology/NewsArticle"/>
    <onto:headline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Acusan a un empleado de Google en EEUU de usar datos confidenciales para ganar 1 millón de dólares en una plataforma de apuestas</onto:headline>
    <onto:content rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Michelle Spagnuolo, que apostaba por las búsquedas de los usuarios en Google, "había accedido a datos internos confidenciales y de gran valor comercial" de la compañía, por lo que conocía los resultados antes que el resto de usuarios&amp;nbsp;Leer</onto:content>
    <onto:sourceURL rdf:resource="https://www.elmundo.es/tecnologia/2026/05/28/6a17da1de4d4d88f128b45be.html"/>
    <onto:publishDate rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Thu, 28 May 2026 08:01:10 +0200</onto:publishDate>
    <onto:writtenBy rdf:resource="http://data.orbitalview.org/instance/person_Efe"/>
    <onto:assignedTo rdf:resource="http://data.orbitalview.org/instance/section_tecnologia"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.orbitalview.org/instance/news_19">
    <rdf:type rdf:resource="http://data.orbitalview.org/ontology/NewsArticle"/>
    <onto:headline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Si no pagas por X sólo podrás publicar 50 mensajes al día</onto:headline>
    <onto:content rdf:datatype="http://www.w3.org/2001/XMLSchema#string">La plataforma de Elon Musk ha reducido drásticamente el número de mensajes y respuestas que pueden enviar los usuarios gratuitos, desde los 2.400 anteriores hasta 50 publicaciones y 200 respuestas al día&amp;nbsp;Leer</onto:content>
    <onto:sourceURL rdf:resource="https://www.elmundo.es/tecnologia/creadores/2026/05/18/6a0b7513fdddfffd188b4597.html"/>
    <onto:publishDate rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mon, 18 May 2026 22:22:56 +0200</onto:publishDate>
    <onto:writtenBy rdf:resource="http://data.orbitalview.org/instance/person_Ángel_Jiménez_de_Luis"/>
    <onto:assignedTo rdf:resource="http://data.orbitalview.org/instance/section_tecnologia"/>
  </rdf:Description>
