    <onto:assignedTo rdf:resource="http://data.orbitalview.org/instance/section_tecnologia"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.orbitalview.org/instance/news_26">
    <rdf:type rdf:resource="http://data.orbitalview.org/ontology/NewsArticle"/>
    <onto:headline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Google lanza Fitbit Air, una pulsera de fitness sin pantalla, y rediseña Google Health como un nuevo servicio</onto:headline>
    <onto:content rdf:datatype="http://www.w3.org/2001/XMLSchema#string">El nuevo dispositivo, el más ligero que ha fabricado Fitbit, se podrá reservar desde hoy y llegará a las tiendas el 26 de mayo&amp;nbsp;Leer</onto:content>
    <onto:sourceURL rdf:resource="https://www.elmundo.es/tecnologia/2026/05/07/69fcda4ffdddffaa2b8b45a0.html"/>
    <onto:publishDate rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Thu, 07 May 2026 20:30:42 +0200</onto:publishDate>
