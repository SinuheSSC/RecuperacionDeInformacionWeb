    onto:writtenBy data:person_Ángel_Jiménez_de_Luis .

data:news_19 a onto:NewsArticle ;
    onto:assignedTo data:section_tecnologia ;
    onto:content "La plataforma de Elon Musk ha reducido drásticamente el número de mensajes y respuestas que pueden enviar los usuarios gratuitos, desde los 2.400 anteriores hasta 50 publicaciones y 200 respuestas al día&nbsp;Leer"^^xsd:string ;
    onto:headline "Si no pagas por X sólo podrás publicar 50 mensajes al día"^^xsd:string ;
    onto:publishDate "Mon, 18 May 2026 22:22:56 +0200"^^xsd:string ;
    onto:sourceURL <https://www.elmundo.es/tecnologia/creadores/2026/05/18/6a0b7513fdddfffd188b4597.html> ;
    onto:writtenBy data:person_Ángel_Jiménez_de_Luis .

data:news_2 a onto:NewsArticle ;
    onto:assignedTo data:section_tecnologia ;
    onto:content "Michelle Spagnuolo, que apostaba por las búsquedas de los usuarios en Google, \"había accedido a datos internos confidenciales y de gran valor comercial\" de la compañía, por lo que conocía los resultados antes que el resto de usuarios&nbsp;Leer"^^xsd:string ;
    onto:headline "Acusan a un empleado de Google en EEUU de usar datos confidenciales para ganar 1 millón de dólares en una plataforma de apuestas"^^xsd:string ;
