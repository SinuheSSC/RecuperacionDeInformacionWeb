data:news_28 a onto:NewsArticle ;
    onto:assignedTo data:section_tecnologia ;
    onto:content "Kyle Andeer, vicepresidente de Legislación Regulatoria y de Productos de Apple, admite que la compañía podría verse forzada a degradar la experiencia de sus productos en la Unión Europea si la Comisión no reconsidera su interpretación de la norma&nbsp;Leer"^^xsd:string ;
